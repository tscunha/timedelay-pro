# =============================================================================
# TimeShift Pro — Configuração do Servidor
# Copie este arquivo para .env e preencha os valores antes de iniciar.
# =============================================================================

# --- Servidor ---
PORT=3000

# --- Nimble Streamer (DVR Backend) ---
# Endereço IP ou hostname da sua instância Nimble Streamer
NIMBLE_HOST=127.0.0.1
# Porta HTTP do Nimble Streamer (padrão: 8081)
NIMBLE_PORT=8081

# --- Autenticação (API Keys por Tenant) ---
# Formato: TENANT_ID:API_KEY separados por vírgula para múltiplos tenants
# Exemplo: "acme:chave-super-secreta-123,globo:outra-chave-456"
# ⚠ NUNCA commite este arquivo com chaves reais!
TENANT_API_KEYS=tenant123:minha-chave-secreta-aqui
