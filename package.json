{
  "name": "timedelay-pro",
  "version": "1.0.0",
  "description": "TimeShift Cloud Orchestrator API",
  "main": "server/index.ts",
  "scripts": {
    "build": "tsc",
    "build:client": "cd client && npm run build",
    "build:all": "npm run build:client && npm run build",
    "start": "node dist/index.js",
    "start:prod": "npm run build:all && node dist/index.js",
    "dev": "ts-node server/index.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@modelcontextprotocol/sdk": "^1.2.0",
    "better-sqlite3": "^11.5.0",
    "cross-spawn": "^7.0.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "jose": "^5.9.6",
    "uuid": "^11.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
